# ─────────────────────────────────────────────
#  icpaste.com — Environment Variables
#  Copy this file to .env.local and fill in
#  your API keys before running the project.
# ─────────────────────────────────────────────

# Mouser Electronics API
# Get your key at: https://www.mouser.com/api-hub/
MOUSER_API_KEY=your_mouser_api_key_here

# Digi-Key API v4
# Register at: https://developer.digikey.com/
DIGIKEY_CLIENT_ID=your_digikey_client_id_here
DIGIKEY_CLIENT_SECRET=your_digikey_client_secret_here

# Farnell / element14 API
# Register at: https://partner.element14.com/
FARNELL_API_KEY=your_farnell_api_key_here

# ─────────────────────────────────────────────
#  Affiliate parameters (append to product URLs)
# ─────────────────────────────────────────────
MOUSER_AFFILIATE_PARAM=
DIGIKEY_AFFILIATE_PARAM=
FARNELL_AFFILIATE_PARAM=

# ─────────────────────────────────────────────
#  Optional: default locale
# ─────────────────────────────────────────────
DEFAULT_LOCALE=en
